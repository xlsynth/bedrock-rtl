load("@rules_hdl//verilog:providers.bzl", "verilog_library")
load("//bazel:br_verilog.bzl", "br_verilog_fpv_test_tools_suite")
load("//bazel:verilog.bzl", "verilog_elab_test")

package(default_visibility = ["//fifo/fpv:__subpackages__"])

verilog_library(
    name = "br_fifo_shared_pop_ctrl_fpv_checker",
    srcs = ["br_fifo_shared_pop_ctrl_fpv_checker.sv"],
    deps = [
        "//fpv/lib:fv_delay",
        "//fpv/lib:fv_valid_ready_check",
        "//macros:br_asserts",
        "//macros:br_registers",
    ],
)

verilog_library(
    name = "br_fifo_shared_pop_ctrl_fpv_monitor",
    srcs = ["br_fifo_shared_pop_ctrl_fpv_monitor.sv"],
    deps = [
        ":br_fifo_shared_pop_ctrl_fpv_checker",
        "//fifo/rtl:br_fifo_shared_pop_ctrl",
    ],
)

verilog_library(
    name = "br_fifo_shared_pop_ctrl_ext_arbiter_fpv_monitor",
    srcs = ["br_fifo_shared_pop_ctrl_ext_arbiter_fpv_monitor.sv"],
    deps = [
        ":br_fifo_shared_pop_ctrl_fpv_checker",
        "//fifo/rtl:br_fifo_shared_pop_ctrl_ext_arbiter",
    ],
)

verilog_elab_test(
    name = "br_fifo_shared_pop_ctrl_fpv_monitor_elab_test",
    custom_tcl_header = "//:elab_test_jg_custom_header.verific.tcl",
    tool = "verific",
    deps = [":br_fifo_shared_pop_ctrl_fpv_monitor"],
)

br_verilog_fpv_test_tools_suite(
    name = "br_fifo_shared_pop_ctrl_test_port",
    elab_opts = ["-parameter Depth 5"],
    params = {
        "NumFifos": [
            "2",
            "4",
        ],
        "NumReadPorts": [
            "1",
            "2",
        ],
    },
    tools = {
        "jg": "br_fifo_shared_pop_ctrl_fpv.jg.tcl",
    },
    top = "br_fifo_shared_pop_ctrl",
    deps = [":br_fifo_shared_pop_ctrl_fpv_monitor"],
)

br_verilog_fpv_test_tools_suite(
    name = "br_fifo_shared_pop_ctrl_test_latency",
    elab_opts = [
        "-parameter Depth 5",
        "-parameter NumFifos 2",
        "-parameter NumReadPorts 1",
    ],
    params = {
        "RamReadLatency": [
            "0",
            "1",
        ],
        "RegisterDeallocation": [
            "0",
            "1",
        ],
        "RegisterPopOutputs": [
            "0",
            "1",
        ],
        "StagingBufferDepth": [
            "1",
            "2",
        ],
    },
    tools = {
        "jg": "br_fifo_shared_pop_ctrl_fpv.jg.tcl",
    },
    top = "br_fifo_shared_pop_ctrl",
    deps = [":br_fifo_shared_pop_ctrl_fpv_monitor"],
)
