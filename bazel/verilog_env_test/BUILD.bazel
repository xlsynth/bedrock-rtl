sh_test(
    name = "wrapper_contents_test",
    srcs = ["wrapper_contents_test.sh"],
    args = [
        "$(location :elab_with_env)",
        "$(location :elab_without_env)",
        "$(location :elab_with_quoted_env)",
    ],
    data = [
        ":elab_with_env",
        ":elab_with_quoted_env",
        ":elab_without_env",
    ],
)

sh_test(
    name = "fpv_sandbox_contents_test",
    srcs = ["fpv_sandbox_contents_test.sh"],
    args = [
        "$(location :fpv_sandbox_with_env.tar.gz)",
        "$(location :fpv_sandbox_with_env_runner.sh)",
    ],
    data = [
        ":fpv_sandbox_with_env.tar.gz",
        ":fpv_sandbox_with_env_runner.sh",
    ],
)

sh_test(
    name = "synth_with_env_test",
    srcs = ["run_wrapper_test.sh"],
    args = ["$(location :synth_with_env)"],
    data = [":synth_with_env"],
)

