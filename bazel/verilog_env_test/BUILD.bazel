verilog_env_analysis_test_suite(
    name = "verilog_env_analysis_tests",
    direct_target = ":elab_with_env",
    fpv_sandbox_target = ":fpv_sandbox_with_env",
    omitted_target = ":elab_without_env",
)

test_suite(
    name = "verilog_env_tests",
    tests = [
        ":elab_with_env",
        ":elab_with_quoted_env",
        ":elab_without_env",
        ":fpv_sandbox_contents_test",
        ":fpv_with_env",
        ":lint_with_env",
        ":sim_with_env",
        ":synth_sandbox_contents_test",
        ":synth_with_env_test",
        ":verilog_env_analysis_tests",
        ":wrapper_contents_test",
    ],
)
