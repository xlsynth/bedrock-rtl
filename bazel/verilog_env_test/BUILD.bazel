load("@bazel_skylib//rules:write_file.bzl", "write_file")
load("@rules_hdl//verilog:providers.bzl", "verilog_library")
load("@rules_shell//shell:sh_test.bzl", "sh_test")
load("//bazel:verilog.bzl", "rule_verilog_elab_test", "rule_verilog_fpv_sandbox", "rule_verilog_fpv_test", "rule_verilog_lint_test", "rule_verilog_sim_test", "rule_verilog_synth", "rule_verilog_synth_sandbox")
load(":verilog_env_analysis_test.bzl", "verilog_env_analysis_test_suite")

_VERILOG_RUNNER_PLUGINS = [
    ":plugins/fake_plugin.py",
    "@rules_hdl//verilog:providers.bzl",
]

verilog_library(
    name = "design",
    srcs = ["test_design.sv"],
)

write_file(
    name = "quoted_runner_env",
    out = "runner_env's.sh",
    content = [
        "#!/usr/bin/env bash",
        "export VERILOG_RUNNER_ENV_TEST_LOADED=1",
        "export VERILOG_RUNNER_PLUGIN_PATH=/hook/verilog_runner_plugins",
    ],
    is_executable = True,
)

rule_verilog_elab_test(
    name = "elab_with_env",
    tool = "fake",
    verilog_runner_data = [],
    verilog_runner_env = ":runner_env.sh",
    verilog_runner_plugins = _VERILOG_RUNNER_PLUGINS,
    verilog_runner_tool = ":fake_verilog_runner.py",
    deps = [":design"],
)

