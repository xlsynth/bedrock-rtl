load("@rules_python//python:defs.bzl", "py_binary", "py_library", "py_test")
load("@rules_python//python/zipapp:py_zipapp_binary.bzl", "py_zipapp_binary")

package(default_visibility = ["//visibility:public"])

exports_files([
    "verilog_runner.py",
    "cli.py",
    "eda_tool.py",
    "plugins.py",
    "util.py",
])

filegroup(
    name = "verilog_runner_data",
    srcs = [
        "cli.py",
        "eda_tool.py",
        "plugins.py",
        "util.py",
    ],
)

py_library(
    name = "util",
    srcs = ["util.py"],
)

py_binary(
    name = "verilog_runner",
    srcs = [
        "cli.py",
        "eda_tool.py",
        "plugins.py",
        "verilog_runner.py",
    ],
    imports = ["."],
    legacy_create_init = False,
    deps = [
        ":util",
    ],
)

py_zipapp_binary(
    name = "verilog_runner_zipapp",
    binary = ":verilog_runner",
)

py_test(
    name = "util_test",
    srcs = ["util_test.py"],
    deps = [":util"],
)
